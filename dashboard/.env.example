# ══════════════════════════════════════════════════════════════════════════════
# Applore Trading POC — Environment Variables Template
# ══════════════════════════════════════════════════════════════════════════════
# INSTRUCTIONS
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your real API keys below
#   3. Never commit .env — it is listed in .gitignore
#
# This file (.env.example) is safe to commit — it contains NO real keys.
# ══════════════════════════════════════════════════════════════════════════════

# ── Whale Alert ───────────────────────────────────────────────────────────────
# Free tier: https://whale-alert.io  (sign up → Dashboard → API Key)
# Allows: 10 req/min, transactions going back 1 hour
WHALE_ALERT_API_KEY=your_whale_alert_api_key_here

# ── CryptoPanic ───────────────────────────────────────────────────────────────
# Free tier: https://cryptopanic.com/developers/api/  (register → get token)
# Allows: BTC-filtered news from aggregated crypto sources
CRYPTOPANIC_API_KEY=your_cryptopanic_api_key_here

# ── Anthropic Claude ──────────────────────────────────────────────────────────
# Required for AI headline classification (bullish/bearish scoring)
# Console: https://console.anthropic.com/settings/keys
# Used model: claude-haiku-4-5 (low cost, fast inference)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
